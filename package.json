{
  "name": "tia-voice",
  "version": "1.0.35",
  "description": "TIA context-aware voice assistant built with Electron, React, and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "verify:packaged-runtime-deps": "node scripts/verifyPackagedRuntimeDeps.mjs",
    "publish-prod": "bash scripts/publishProd.sh",
    "publish-prod:preflight": "bash scripts/publishProd.sh --preflight-only",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir && npm run verify:packaged-runtime-deps -- dist",
    "build:win": "npm run build && electron-builder --win && npm run verify:packaged-runtime-deps -- dist",
    "build:mac": "electron-vite build && electron-builder --mac && npm run verify:packaged-runtime-deps -- dist",
    "build:linux": "electron-vite build && electron-builder --linux && npm run verify:packaged-runtime-deps -- dist"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@jimp/custom": "^0.22.12",
    "@jimp/plugins": "^0.22.12",
    "@jimp/types": "^0.22.12",
    "@noble/ciphers": "^2.1.1",
    "@noble/hashes": "^2.0.1",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "atomically": "^2.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "debounce-fn": "^6.0.0",
    "electron-updater": "^6.3.9",
    "end-of-stream": "^1.4.5",
    "fast-deep-equal": "^3.1.3",
    "fast-uri": "^3.1.0",
    "file-uri-to-path": "^1.0.0",
    "jimp": "^0.22.10",
    "json-schema-traverse": "^1.0.0",
    "json-schema-typed": "^8.0.2",
    "kysely": "^0.28.15",
    "lucide-react": "^0.575.0",
    "ms": "^2.1.3",
    "once": "^1.4.0",
    "react-router-dom": "^7.14.0",
    "regenerator-runtime": "^0.13.11",
    "selection-hook": "^2.0.1",
    "tailwind-merge": "^3.5.0",
    "type-fest": "^5.5.0",
    "uiohook-napi": "^1.5.5",
    "when-exit": "^2.1.5",
    "wrappy": "^1.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/asar": "^3.4.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^29.0.2",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "shadcn": "^4.2.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.3"
  }
}
